"""Regression test: `py_venv_zipapp` must accept a stock `py_binary`."""

load("@bazel_skylib//rules:diff_test.bzl", "diff_test")
load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@rules_python//python:defs.bzl", "py_binary")
load("//python/venv:defs.bzl", "py_venv_zipapp")
load("//python/venv/private/tests/zipapp:python_zip_file_consumer.bzl", "python_zip_file_consumer")

# Stock py_binary (NOT py_venv_binary) — the whole point of this test.
py_binary(
    name = "writer",
    srcs = ["writer.py"],
)

py_venv_zipapp(
    name = "writer_zipapp",
    binary = ":writer",
)

write_file(
    name = "expected",
    out = "expected.txt",
    content = [
        "La-Li-Lu-Le-Lo",
        "",
    ],
    newline = "unix",
)

python_zip_file_consumer(
    name = "python_zip_file_consumer",
    zip_file = ":writer_zipapp",
)

diff_test(
    name = "python_zip_file_diff_test",
    file1 = "expected.txt",
    file2 = ":python_zip_file_consumer",
)
